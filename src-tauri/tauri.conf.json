{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Manna Palace POS",
  "version": "0.1.1",
  "identifier": "com.mannapalace.cafeteriapos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Manna Palace POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.convex.cloud https://*.convex.site wss://*.convex.cloud ws://*.convex.cloud; img-src 'self' data: https: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data:"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
      "resources": ["../src/assets/logo.png"]
  },
  "plugins": {
    "sql": {}
  }
}
